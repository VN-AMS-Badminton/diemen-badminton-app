{
  "name": "diemen-badminton-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "^22 || >=24"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "cf:build": "pnpm install --frozen-lockfile && pnpm opennextjs-cloudflare build",
    "cf:version:dev": "pnpm wrangler versions upload --env dev",
    "cf:deploy:dev": "pnpm wrangler deploy --env dev",
    "cf:deploy:prd": "pnpm wrangler deploy --env prd",
    "cf-typegen": "wrangler types --env prd --env-interface CloudflareEnv",
    "hash-pin": "tsx scripts/hash-pin.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:studio": "open http://127.0.0.1:54323",
    "db:migrate:new": "supabase migration new",
    "db:env": "bash scripts/write-local-env.sh",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/postcss": "^4.3.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "eslint": "^10.4.1",
    "eslint-config-next": "^16.2.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.99.0"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916"
}
